# Rehab CRM — environment variables
# Copy this file to ".env" for local dev, and set the same two variables in
# Vercel for production. Without them, the app runs offline on LocalStorage only.
#
# Find both values in your Supabase dashboard:
#   Project Settings → API → "Project URL" and "Project API keys → anon public".
# The anon key is safe to expose in a front-end app.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
